# API
PORT=8080
NODE_ENV=development

# Database (заполнить при подключении)
# Локально: localhost:5433 (проброшенный порт из docker-compose)
# Внутри docker-сети сервис api использует host "db" (см. docker-compose.yml)
DATABASE_URL=postgresql://petplatform:petplatform@localhost:5433/petplatform

# Telegram
TELEGRAM_BOT_TOKEN=
# MINI_APP_URL: HTTPS domain registered in BotFather for Web App buttons
MINI_APP_URL=
# WEBHOOK_URL: full HTTPS domain for production webhook (leave blank to use long-polling in dev)
WEBHOOK_URL=

# JWT
JWT_SECRET=change-me-in-production

# Payments (sandbox-ключи; получить в кабинете провайдера)
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
UZUM_MERCHANT_ID=
APP_URL=https://app.happytails.uz
