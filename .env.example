# API
PORT=8080
NODE_ENV=development

# Database (заполнить при подключении)
# Локально: localhost:5433 (проброшенный порт из docker-compose)
# Внутри docker-сети сервис api использует host "db" (см. docker-compose.yml)
DATABASE_URL=postgresql://petplatform:petplatform@localhost:5433/petplatform

# Telegram
TELEGRAM_BOT_TOKEN=
# MINI_APP_URL: HTTPS domain registered in BotFather for Web App buttons
MINI_APP_URL=
# WEBHOOK_URL: public HTTPS domain of your API server (e.g. https://api.happytails.uz)
# When set, the bot switches from long-polling to webhook mode.
# Telegram will POST updates to WEBHOOK_URL/bot, which the API proxies to the bot container.
# Leave blank to use long-polling (suitable for local dev).
WEBHOOK_URL=

# JWT
JWT_SECRET=change-me-in-production

# Payments (sandbox-ключи; получить в кабинете провайдера)
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
UZUM_MERCHANT_ID=
UZUM_SECRET_KEY=
APP_URL=https://app.happytails.uz
BOT_USERNAME=HappyTailsUzBot

# AI vet chat (Anthropic)
ANTHROPIC_API_KEY=
